# Appwrite Configuration
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://appwrite.nrep.ug/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_database_id
NEXT_PUBLIC_RETC_ORG_ID=your_retc_org_id
NEXT_PUBLIC_NREP_ORG_ID=your_nrep_org_id

# Server-side API key (password reset + admin Users ops). Never use NEXT_PUBLIC_*.
APPWRITE_API_KEY=your_appwrite_api_key_with_users_read_write

# Public app URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email / SMTP (EMAIL_* preferred; SMTP_* also supported)
EMAIL_HOST=mail.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=noreply@example.com
EMAIL_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Asset Management

# Optional cron secret for return-reminder API
# CRON_SECRET=your_random_secret
