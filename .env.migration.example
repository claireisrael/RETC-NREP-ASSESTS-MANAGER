# ============================================================
# User migration config (copy to .env.migration.local and fill in)
# NEVER commit the filled-in file. .env.migration.local is git-ignored.
# ============================================================

# --- SOURCE project (where we READ users' names + emails from) ---
# If the source is Appwrite Cloud, use https://cloud.appwrite.io/v1 (or your region host)
SOURCE_APPWRITE_ENDPOINT=https://appwrite.nrep.ug/v1
SOURCE_APPWRITE_PROJECT_ID=66bcc8450005201fa1af
SOURCE_APPWRITE_API_KEY=REPLACE_WITH_SOURCE_API_KEY

# --- DESTINATION project (this system, where we CREATE users) ---
DEST_APPWRITE_ENDPOINT=https://appwrite.nrep.ug/v1
DEST_APPWRITE_PROJECT_ID=68926e9b000ac167ec8a
DEST_APPWRITE_API_KEY=REPLACE_WITH_DEST_API_KEY
DEST_APPWRITE_DATABASE_ID=68a2f2eb0005730f1c97
# Staff collection id (from lib/appwrite/config.js COLLECTIONS.STAFF)
DEST_STAFF_COLLECTION_ID=68a2f49900122499000a

# --- Migration behavior ---
# orgId to stamp on each imported staff record (get from your org env vars / Appwrite)
MIGRATION_ORG_ID=REPLACE_WITH_ORG_ID
MIGRATION_DEFAULT_ROLE=STAFF
# Optional: use one shared temp password for everyone instead of unique random ones
# MIGRATION_SHARED_PASSWORD=ChangeMe123!
MIGRATION_CSV_PATH=scripts/migrated-credentials.csv
